    "10": { correct: "b", correctText: "Mohenjo-daro", exp: "Kot Diji lies in Sindh on the left bank of the Indus, close to Mohenjo-daro. It is a key pre-Harappan/Early Harappan site, not near Harappa, Lothal or Kalibangan." },
    "11": { correct: "a", correctText: "Sukkur and Rohri Hills", exp: "The Sukkur and Rohri hills in Sindh were the factory sites where limestone and chert blades were mass-produced and distributed to Harappan settlements. Khetri (copper) and the Baluchistan/Chagai hills are not the blade sources." },
    "12": { correct: "c", correctText: "Dholavira", exp: "Dholavira (Gujarat) is famous for its sophisticated water management — large rock-cut cisterns and reservoirs in the citadel and lower town. Banawali, Mohenjodaro and Rakhigarhi are not noted for these large reservoirs." },
